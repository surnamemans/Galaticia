// Rust source code for a game launcher

use std::process::Command;

fn main() {
    println!("Launching game...");
    let game_path = "path_to_your_game.exe";

    match Command::new(game_path).spawn() {
        Ok(_) => println!("Game launched successfully!"),
        Err(e) => eprintln!("Failed to launch game: {}", e),
    }
}